# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Supabase (Backend — service role, never expose to frontend) ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Supabase (Frontend — anon key, safe for client) ─────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=

# ─── Schwab / TD Ameritrade ───────────────────────────────────
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=http://localhost:8001/auth/callback

# ─── Python Microservice ──────────────────────────────────────
PYTHON_MS_URL=http://localhost:8001
PYTHON_MS_API_KEY=

# ─── News Data ────────────────────────────────────────────────
# Get a free key at https://newsapi.org/register
# Optional — mock headlines are used if not set
NEWS_API_KEY=

# ─── Notifications ────────────────────────────────────────────
SLACK_WEBHOOK_URL=
NOTIFICATION_EMAIL=

# ─── App Config ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost:3001

# ─── Trading Config ───────────────────────────────────────────
# Set to 'paper' for paper trading, 'live' for real money (requires explicit opt-in)
TRADING_MODE=paper
